{
  "_doc": "BCE-emergence study: 2 loss styles (bce = patch+image BCE, cont = WACV contrastive recipe) x 3 train mixes (inpaint = sagid+coco_inpaint, splice = casia ONLY — IMD is NEVER trained on, both = 50/50). Standard 448/r16 recipe, fresh LoRA, paste_frac 0.40 (60% fr keeps regen noise in negative background). fr_bg_negative_prob 0.12 on every inpaint-trained cell: un-pasted fr items occasionally serve an outside-mask crop as a clean negative (isolates the decoder fingerprint from the semantic heads). Cells named *_s0 = seed 42; replicates are re-queues with a new seed suffix. Run via run_scripts/run_bce_emergence_queue.sh (dynamic 2-GPU claiming).",
  "base_args": {
    "device": "cuda",
    "imd2020_root": "/media/ssd/DINO_SCOPE_DATA/IMD2020",
    "casia_root": "/media/ssd/DINO_SCOPE_DATA/casia",
    "sagid_root": "/media/ssd/DINO_SCOPE_DATA/SAGI_D",
    "coco_inpaint_root": "/media/ssd/DINO_SCOPE_DATA/INPAINT_COCO/content/inpaint_coco/images",
    "tgif2_root": "/media/ssd/DINO_SCOPE_DATA/content/flux_originals",
    "casia_train": true,
    "imd_val_only": true,
    "image_size": 448,
    "patch_size": 16,
    "lora_rank": 16,
    "lora_alpha": 32,
    "batch_size": 8,
    "grad_accum": 1,
    "contrastive_dim": 64,
    "pool_hidden": 256,
    "lambda_image_bce": 1.0,
    "paste_frac": 0.40,
    "seed": 42,
    "train_samples": 3000,
    "num_workers": 4,
    "num_epochs": 10,
    "min_epochs": 5,
    "warmup_epochs": 1.0,
    "early_stop_patience": 2,
    "early_stop_reduce": "mean",
    "val_zoom": true,
    "tgif_val_models": "flux1dev",
    "val_per_cell": 100
  },
  "runs": [
    {"name": "bce_inpaint_s0", "module": "experiments.scripts.train",
     "args": {"patch_bce": true, "lambda_contrastive": 0.0, "lambda_patch_bce": 1.0,
              "fr_bg_negative_prob": 0.12,
              "splice_mix": ["sagid=0.5", "coco_inpaint=0.5"]}},
    {"name": "bce_splice_s0", "module": "experiments.scripts.train",
     "args": {"patch_bce": true, "lambda_contrastive": 0.0, "lambda_patch_bce": 1.0,
              "splice_mix": ["casia=1.0"]}},
    {"name": "bce_both_s0", "module": "experiments.scripts.train",
     "args": {"patch_bce": true, "lambda_contrastive": 0.0, "lambda_patch_bce": 1.0,
              "fr_bg_negative_prob": 0.12,
              "splice_mix": ["sagid=0.25", "coco_inpaint=0.25", "casia=0.5"]}},
    {"name": "cont_inpaint_s0", "module": "experiments.scripts.train",
     "args": {"lambda_contrastive": 2.0,
              "fr_bg_negative_prob": 0.12,
              "splice_mix": ["sagid=0.5", "coco_inpaint=0.5"]}},
    {"name": "cont_splice_s0", "module": "experiments.scripts.train",
     "args": {"lambda_contrastive": 2.0,
              "splice_mix": ["casia=1.0"]}},
    {"name": "cont_both_s0", "module": "experiments.scripts.train",
     "args": {"lambda_contrastive": 2.0,
              "fr_bg_negative_prob": 0.12,
              "splice_mix": ["sagid=0.25", "coco_inpaint=0.25", "casia=0.5"]}}
  ]
}
