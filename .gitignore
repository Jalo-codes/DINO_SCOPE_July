# Results and checkpoints - never commit these.
# NOTE: `results/*` (not `results/`) so the ablation-analysis exception at the
# bottom can re-include files — git cannot un-ignore a file whose parent dir is
# excluded, so the directory itself must stay listable.
results/*
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors

# Data

*.h5
*.npy
*.npz
*.csv

# Python
__pycache__/
*.pyc
*.pyo
.env
*.egg-info/
dist/
.eggs/

# Jupyter - strip outputs before committing
.ipynb_checkpoints/

# Colab
*.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.d

#claude
.claude/

# Test fixtures are an exception to the *.pt / *.npz / *.csv ignores above:
# the golden checkpoint + cached ModelInfo (GAMEPLAN C1/C2) must be committable.
!tests/fixtures/
!tests/fixtures/**

# Ablation analysis artifacts ARE committed. We track ONLY the small text
# outputs of the ablation eval/training sweeps under results/ablation/:
# per-cell orchestrator logs, eval_summary.json, and rollup CSVs. The *.csv
# negation overrides the global *.csv ignore above. Checkpoints/images that may
# share the tree stay ignored because we never un-ignore *.pt / image globs.
!results/ablation/
!results/ablation/**/*.log
!results/ablation/**/*.json
!results/ablation/**/*.csv

# Qualitative visuals (zoom debug panels) ARE committed — small PNGs only.
!results/visuals/
!results/visuals/**/*.png

# IEDAL2 challenge submission repo — own git repo (GitLab remote, Apache-2.0
# license, unrelated history), just nested here physically for convenience.
# Never let the parent repo track it or turn it into a submodule gitlink.
iedal2/
